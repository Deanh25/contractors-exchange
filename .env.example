# Copy this file to `.env` and fill in local values. `.env` is gitignored.

# --- Database (local MySQL via XAMPP) ---
# XAMPP default is user "root" with an empty password. Create the DB once:
#   mysql -u root -e "CREATE DATABASE contractors_exchange"
DATABASE_URL="mysql://root:@127.0.0.1:3306/contractors_exchange"

# --- Auth (Auth.js / NextAuth) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# --- File storage (local filesystem in dev) ---
UPLOAD_DIR="./public/uploads"
