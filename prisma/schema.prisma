// Contractors Exchange - Prisma schema.
// Provider is MySQL/MariaDB (local via XAMPP). To move to Postgres later: change
// `provider` below, swap the driver adapter in src/lib/prisma.ts, update DATABASE_URL.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// -----------------------------------------------------------------------------
// Identity (PRD §2 - the spine): dual identity. A User is a person; a Company is
// a business. Membership links people to companies and carries permissions.
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  title     String? // role / title, e.g. "Owner", "Estimator"
  bio       String?  @db.Text
  // Trade slugs (controlled vocabulary in src/lib/trades.ts). MySQL has no scalar
  // arrays, so we store a JSON array of strings; null is treated as []. Portable to Postgres.
  trades    Json?
  city      String?
  state     String?
  lat       Float?
  lng       Float?
  avatarUrl String?
  verified  Boolean  @default(false) // manual trust flag (PRD §7)
  suspended Boolean  @default(false) // soft-suspended by an admin (reversible, PRD §7C)
  // Admin backend access + privilege level (PRD §7C). `none` = not an admin.
  // Hierarchy: superadmin > admin > moderator. Gating is server-side only.
  adminRole AdminRole @default(none)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  listings    Listing[] // listings owned as a sole operator
  posts       Post[] // discussion posts authored as an individual
  follows     Follow[] // trades/locations/companies/people this user follows
  threadsAsUserA Thread[] @relation("ThreadAUser") // threads where this user is party A
  threadsAsUserB Thread[] @relation("ThreadBUser") // threads where this user is party B
  messagesSent   Message[] @relation("MessageSenderUser") // messages this user typed
  purchasesAsUser Transaction[] @relation("TxBuyerUser") // deals where this user is the buyer
  salesAsUser     Transaction[] @relation("TxSellerUser") // deals where this user is the seller
  reviewsWritten  Review[] @relation("ReviewRaterUser") // reviews this user wrote
  reviewsReceived Review[] @relation("ReviewRateeUser") // reviews about this user (personal)
  notifications      Notification[] @relation("NotifRecipientUser") // alerts for this user
  notificationsActed Notification[] @relation("NotifActorUser") // alerts this user triggered
  savedListings      SavedListing[] // listings this user bookmarked
  collections        Collection[] // named folders for saved listings
  taggedInPosts      PostTag[] @relation("PostTagUser") // posts that mention this user
  adminActions       AdminAction[] @relation("AdminActions") // moderation actions this admin took
  listingViews       ListingView[] @relation("ListingViewViewer") // listing detail views by this user
  offersAsBuyer      Offer[] @relation("OfferBuyerUser") // offers this user made as a buyer
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  trades      Json? // JSON array of trade slugs (see note on User.trades)
  serviceArea String? // free-text service area description
  city        String?
  state       String?
  lat         Float?
  lng         Float?
  logoUrl     String?
  description String?  @db.Text
  verified    Boolean  @default(false)
  suspended   Boolean  @default(false) // soft-suspended by an admin (reversible, PRD §7C)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]
  listings    Listing[] // the company storefront
  posts       Post[] // discussion posts authored as the company
  threadsAsCompanyA Thread[]  @relation("ThreadACompany") // threads where this company is party A
  threadsAsCompanyB Thread[]  @relation("ThreadBCompany") // threads where this company is party B
  messagesSent      Message[] @relation("MessageSenderCompany") // messages sent as this company
  reviewsWritten    Review[]  @relation("ReviewRaterCompany") // reviews written as this company
  reviewsReceived   Review[]  @relation("ReviewRateeCompany") // reviews about this company
  purchasesAsCompany Transaction[] @relation("TxBuyerCompany") // deals where this company is the buyer
  salesAsCompany     Transaction[] @relation("TxSellerCompany") // deals where this company is the seller (storefront)
  notifications      Notification[] @relation("NotifRecipientCompany") // alerts for this company's team
  notificationsActed Notification[] @relation("NotifActorCompany") // alerts this company triggered
  taggedInPosts      PostTag[] @relation("PostTagCompany") // posts that mention this company
  offersAsBuyer      Offer[] @relation("OfferBuyerCompany") // offers this company made as a buyer
}

enum MembershipRole {
  owner
  member
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  companyId String
  role      MembershipRole @default(member)
  // Whether this member may act AS the company (post/list/message as it, manage
  // its orders, receive its notifications). Owners can always act; owners grant
  // this to members on the Team tab. See company-as-actor design.
  canActAsCompany Boolean  @default(false)
  createdAt DateTime       @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId]) // a person belongs to a company at most once
  @@index([companyId])
}

// -----------------------------------------------------------------------------
// Marketplace (PRD §3). Every listing carries a single trade category and a
// location, owned by either a User (sole operator) or a Company (storefront).
// Exactly one of ownerUserId / ownerCompanyId is set - enforced in the action.
// -----------------------------------------------------------------------------

// Four UI choices collapse to three types: a "trade" listing is further split by
// tradeKind into goods vs. services. Field exclusivity (price vs. bid vs. trade)
// is enforced at the validation layer (PRD §10 constraint).
enum ListingType {
  price // fixed "buy now" price
  bid // starting/reserve bid + close date
  trade // swap goods or services (no escrow - see PRD §6)
}

enum TradeKind {
  goods
  service
}

// Condition for physical goods (PRD marketplace filters).
enum ListingCondition {
  new
  like_new
  good
  fair
  salvage
}

enum ListingStatus {
  active
  sold // a set-price listing that completed
  awarded // a bid listing that closed with a winner
  closed // withdrawn / expired
}

model Listing {
  id String @id @default(cuid())
  // Polymorphic owner via two optional FKs (exactly one is set). This keeps clean
  // Prisma relations / `include` while matching the PRD's owner_type/owner_id intent.
  ownerUserId    String?
  ownerCompanyId String?

  title         String
  tradeCategory String // single trade slug (controlled vocab in src/lib/trades.ts)
  city          String?
  state         String?
  lat           Float?
  lng           Float?
  description   String? @db.Text
  unit          String? // e.g. "per ton", "each", "per pallet"
  freightNote   String? // free-text only in v1 (PRD §9 - no freight calc)
  condition     ListingCondition? // physical-goods condition (filterable)
  manufacturer  String? // brand / make (filterable), free text
  photos        Json? // JSON array of public URL strings (see src/lib/storage.ts)

  type ListingType

  // Type-exclusive fields (null unless the matching type is selected):
  price        Decimal?   @db.Decimal(12, 2) // type=price - PUBLIC buyer price
  startReserve Decimal?   @db.Decimal(12, 2) // type=bid (starting/reserve amount)
  closesAt     DateTime? // type=bid
  tradeKind    TradeKind? // type=trade

  // Stock for set-price listings: 1 = a unique item (single "Buy"), >1 = stockable
  // (quantity stepper capped at this number, "Add to cart").
  quantityAvailable Int @default(1)

  // Margin pricing (PRD §7B, corrected model), set-price listings only. The seller
  // enters a PRIVATE net; the public `price` = net x (1 + marginPct/100). sellerNet
  // and marginPct are NEVER shown to buyers (owner/admin only). The stored
  // sellerNet + marginPct + listedAt ARE the seller's consent record (they agreed
  // to net X at margin % when listing). Buyer negotiation later moves the net, not
  // the margin (see Offer).
  sellerNet       Decimal?  @db.Decimal(12, 2) // private: what the seller takes home
  marginPct       Float? // private: fixed category margin % applied to reach `price`
  acceptsOffers   Boolean   @default(true) // set-price listings are negotiable by default
  listedAt        DateTime? // when the listing went live (consent moment / aging)
  lastRepricedAt  DateTime? // last aging reprice

  status    ListingStatus @default(active)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  ownerUser    User?    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  ownerCompany Company? @relation(fields: [ownerCompanyId], references: [id], onDelete: Cascade)
  threads      Thread[] // message threads about this listing
  transactions Transaction[] // purchase / bid / trade-request records
  savedBy      SavedListing[] // users who bookmarked this listing
  views        ListingView[] // detail-page view events (Marketplace Insights)
  offers       Offer[] // buyer offers / counters (negotiation)

  @@index([tradeCategory])
  @@index([type])
  @@index([status])
  @@index([ownerUserId])
  @@index([ownerCompanyId])
  @@index([createdAt])
}

// A listing detail-page view event (PRD: Marketplace Insights, seller analytics).
// One row per counted visit; the owner's own views are not recorded. viewerUserId
// is null for logged-out visitors. The SAME event source feeds the seller's
// per-listing insight AND (later) the admin dashboard, so it lives here once.
// Repeat views by the same signed-in user within a short window are de-duped at
// write time (see src/lib/insights.ts) so a refresh doesn't inflate Views.
model ListingView {
  id           String   @id @default(cuid())
  listingId    String
  viewerUserId String? // null = anonymous / logged-out
  source       String? // where the view came from, e.g. "detail"
  createdAt    DateTime @default(now())

  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewerUser User?   @relation("ListingViewViewer", fields: [viewerUserId], references: [id], onDelete: SetNull)

  @@index([listingId, createdAt])
  @@index([viewerUserId])
}

// Admin privilege levels (PRD §7C). Clean hierarchy + one inversion: a moderator
// is trust & safety ONLY and must never see financial fields (sellerNet/margin).
//   superadmin: everything (manage admins, edit margin bands, hard delete, financials)
//   admin:      operational work + financials, but NOT admin mgmt or margin bands
//   moderator:  listing/content moderation + verification ONLY, NO financials
enum AdminRole {
  none
  moderator
  admin
  superadmin
}

// Admin audit log (PRD §7C): every moderation/config action an admin takes is
// recorded here for accountability (who did what to which entity, when).
model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  action     String // e.g. "pricing.approve", "user.verify", "margin.update"
  targetType String // "listing" | "user" | "company" | "margin"
  targetId   String?
  detail     String?  @db.Text // human-readable summary / notes
  createdAt  DateTime @default(now())

  admin User @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([adminId])
}

// Per-category margin (PRD §7B, corrected revenue model). A FLAT, fixed margin %
// per assignable category (the trade slug a listing is assigned to - CX has no
// category hierarchy, so this is the most granular level). buyerPrice =
// sellerNet x (1 + marginPct/100). The % is always honored and never flexes
// during a sale; buyer negotiation moves the seller's NET, not the margin. Tuned
// by a superadmin in the admin panel without code. Falls back to a code default.
model CategoryMargin {
  id        String   @id @default(cuid())
  category  String   @unique // trade slug (src/lib/trades.ts)
  marginPct Float
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Community + Feed (PRD §4-§5). Discussion posts are light, text-first content
// tagged by trade and/or region. Follows shape the unified feed: a user follows
// trades, locations, companies, and people; the feed mixes listings + posts from
// what they follow, reverse-chronologically (NOT an algorithmic ranking).
// -----------------------------------------------------------------------------

model Post {
  id String @id @default(cuid())
  // Polymorphic author (mirrors Listing's owner): a User or a Company, one set.
  authorUserId    String?
  authorCompanyId String?

  body      String  @db.Text
  imageUrl  String?
  tradeTag  String? // optional trade slug (controlled vocab in src/lib/trades.ts)
  regionTag String? // optional region: a state code (e.g. "AZ") for simple matching

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorUser    User?    @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  authorCompany Company? @relation(fields: [authorCompanyId], references: [id], onDelete: Cascade)
  tags          PostTag[] // users / companies mentioned in this post

  @@index([tradeTag])
  @@index([regionTag])
  @@index([authorUserId])
  @@index([authorCompanyId])
  @@index([createdAt])
}

// A mention/tag in a post: a tagged PARTY (a user or a company). Tagged parties
// get linked in the post and notified (company-as-actor: tag people or pages).
model PostTag {
  id              String   @id @default(cuid())
  postId          String
  taggedUserId    String?
  taggedCompanyId String?
  createdAt       DateTime @default(now())

  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  taggedUser    User?    @relation("PostTagUser", fields: [taggedUserId], references: [id], onDelete: Cascade)
  taggedCompany Company? @relation("PostTagCompany", fields: [taggedCompanyId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([taggedUserId])
  @@index([taggedCompanyId])
}

enum FollowTargetType {
  trade // targetValue = trade slug
  location // targetValue = state code (e.g. "AZ")
  company // targetValue = Company id
  user // targetValue = User id
}

model Follow {
  id             String           @id @default(cuid())
  followerUserId String
  targetType     FollowTargetType
  targetValue    String
  createdAt      DateTime         @default(now())

  follower User @relation(fields: [followerUserId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, targetType, targetValue]) // follow each target once
  @@index([followerUserId])
  @@index([targetType, targetValue])
}

// -----------------------------------------------------------------------------
// Messaging (PRD §6). Simple 1:1 threads between two users, optionally about a
// listing. Participants are canonicalized (userAId < userBId) so a pair has one
// thread per listing context. Company-owned listings/pages are messaged via the
// company's owner. Leakage-aware completion (Buy/Bid/Complete) surfaces in the
// thread UI; real money moves in Step 6. NOT group chat / real-time (PRD §9).
// -----------------------------------------------------------------------------

// A conversation party is polymorphic: a User or a Company (company-as-actor).
enum PartyType {
  user
  company
}

model Thread {
  id        String   @id @default(cuid())
  // Two parties, canonically ordered by partyKey = "<type>:<id>" so a pair maps
  // to one thread. Exactly one of (aUserId, aCompanyId) is set, per side.
  aType      PartyType
  aUserId    String?
  aCompanyId String?
  bType      PartyType
  bUserId    String?
  bCompanyId String?
  listingId  String? // optional context: the listing this conversation is about
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt // bumped on each new message (for inbox sorting)
  // When each side last opened the thread (for unread state). For a company
  // side this is shared across the team (first reader clears it) - v1 simplification.
  aLastReadAt DateTime?
  bLastReadAt DateTime?

  aUser     User?    @relation("ThreadAUser", fields: [aUserId], references: [id], onDelete: Cascade)
  aCompany  Company? @relation("ThreadACompany", fields: [aCompanyId], references: [id], onDelete: Cascade)
  bUser     User?    @relation("ThreadBUser", fields: [bUserId], references: [id], onDelete: Cascade)
  bCompany  Company? @relation("ThreadBCompany", fields: [bCompanyId], references: [id], onDelete: Cascade)
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages  Message[]

  // Best-effort uniqueness (MySQL treats NULLs as distinct, so the action also
  // de-dupes explicitly).
  @@unique([aType, aUserId, aCompanyId, bType, bUserId, bCompanyId, listingId])
  @@index([aUserId])
  @@index([aCompanyId])
  @@index([bUserId])
  @@index([bCompanyId])
  @@index([updatedAt])
}

model Message {
  id              String   @id @default(cuid())
  threadId        String
  // The human who typed it, plus the identity they acted as (company), if any.
  senderUserId    String
  senderCompanyId String? // null = sent as themselves; set = sent as this company
  body            String   @db.Text
  imageUrl        String?
  createdAt       DateTime @default(now())

  thread        Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUser    User     @relation("MessageSenderUser", fields: [senderUserId], references: [id], onDelete: Cascade)
  senderCompany Company? @relation("MessageSenderCompany", fields: [senderCompanyId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Transactions (PRD §7, STUBBED in v1). A purchase / bid / trade-request creates
// a record and notifies the seller; escrow / buyer protection is represented in
// the UI but NO money moves yet (Phase 2 makes it real). sellerId is denormalized
// to the listing's owning user (a company's primary owner) so both sides can
// query their deals without re-resolving ownership.
// -----------------------------------------------------------------------------

enum TransactionType {
  purchase // a set-price "buy now"
  bid // an offer on a bid listing
  trade_request // a goods/services exchange request (no escrow)
}

enum TransactionStatus {
  pending // created, awaiting the seller
  accepted // seller accepted / awarded
  declined // seller declined
  completed // fulfilled on-platform (feeds reviews in Step 7)
  cancelled // buyer withdrew
}

model Transaction {
  id        String @id @default(cuid())
  listingId String
  // Buyer and seller are PARTIES (a user or a company), so a company's deals
  // form its own orders book, separate from any member's personal orders.
  buyerType       PartyType
  buyerUserId     String?
  buyerCompanyId  String?
  sellerType      PartyType
  sellerUserId    String?
  sellerCompanyId String?
  type      TransactionType
  amount    Decimal?          @db.Decimal(12, 2) // null for trade requests
  // Spread pricing (PRD §7B): buyerPrice is public; sellerNet/margin are private
  // (filtered from buyer-facing views). Populated simply for now (buyerPrice =
  // amount) until the full per-category margin + agreement flow lands.
  buyerPrice Decimal?         @db.Decimal(12, 2)
  sellerNet  Decimal?         @db.Decimal(12, 2)
  margin     Decimal?         @db.Decimal(12, 2)
  quantity  Int               @default(1) // units purchased (set-price); decrements stock on completion
  message   String?           @db.Text
  status    TransactionStatus @default(pending)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerUser     User?    @relation("TxBuyerUser", fields: [buyerUserId], references: [id], onDelete: Cascade)
  buyerCompany  Company? @relation("TxBuyerCompany", fields: [buyerCompanyId], references: [id], onDelete: Cascade)
  sellerUser    User?    @relation("TxSellerUser", fields: [sellerUserId], references: [id], onDelete: Cascade)
  sellerCompany Company? @relation("TxSellerCompany", fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([listingId])
  @@index([buyerUserId])
  @@index([buyerCompanyId])
  @@index([sellerUserId])
  @@index([sellerCompanyId])
  @@index([status])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Offers / negotiation (PRD §7B, corrected model). A buyer negotiates a set-price
// listing by proposing a BUYER PRICE; the system back-calculates the implied
// seller net at the listing's FIXED margin ( net = buyerPrice / (1 + margin%) ).
// The margin % never moves - only the net. Counters alternate buyer/seller and
// chain via parentId; the latest pending offer awaits the OTHER side. On accept a
// Transaction is created. sellerNet/marginPct are private (seller/admin only).
// -----------------------------------------------------------------------------

enum OfferSide {
  buyer
  seller
}

enum OfferStatus {
  pending // open, awaiting the other side
  accepted // accepted -> a Transaction was created
  declined // declined by the recipient
  countered // superseded by the recipient's counter
  withdrawn // the sender withdrew it
}

model Offer {
  id String @id @default(cuid())
  listingId String
  // The buyer party in this negotiation (constant across the counter chain).
  buyerType      PartyType
  buyerUserId    String?
  buyerCompanyId String?
  fromSide   OfferSide // who proposed THIS offer (negotiation alternates)
  buyerPrice Decimal   @db.Decimal(12, 2) // proposed PUBLIC buyer price
  sellerNet  Decimal   @db.Decimal(12, 2) // private: implied net at the fixed margin
  marginPct  Float // private: listing's fixed margin % at offer time
  message    String?   @db.Text
  status     OfferStatus @default(pending)
  parentId   String? // the offer this one counters (chain)
  threadId   String? // the messaging thread the negotiation lives in
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerUser    User?    @relation("OfferBuyerUser", fields: [buyerUserId], references: [id], onDelete: Cascade)
  buyerCompany Company? @relation("OfferBuyerCompany", fields: [buyerCompanyId], references: [id], onDelete: Cascade)

  @@index([listingId, status])
  @@index([buyerUserId])
  @@index([buyerCompanyId])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Notifications (PRD §8 + company-as-actor). In-app alerts on key events. The
// recipient is a PARTY: a user, OR a company (its permitted team sees the single
// record in their bell, labeled with the company; shared read - first reader
// clears it for the team). The actor records the human + the identity acted as.
// readAt = null means unread (drives the bell badge).
// -----------------------------------------------------------------------------

enum NotificationType {
  message // a new message arrived in a thread
  order_new // someone started a deal on your listing
  order_update // a deal you are in changed status
  review_new // you received a review
  follow_new // someone followed you
  post_mention // you (or your company) were tagged in a post
  offer_new // someone made an offer on your listing
  offer_update // an offer you are in was countered / accepted / declined
}

model Notification {
  id String @id @default(cuid())
  // Recipient party: exactly one of these is set.
  recipientUserId    String?
  recipientCompanyId String?
  type          NotificationType
  // Actor: the human who triggered it + the identity they acted as (for avatar).
  actorUserId    String?
  actorCompanyId String?
  title         String // short headline, e.g. "New message from Dean"
  body          String?          @db.Text // optional preview / detail
  href          String // where clicking the notification navigates
  threadId      String? // loose entity refs (no FK cascade needed)
  listingId     String?
  transactionId String?
  readAt        DateTime? // null = unread
  createdAt     DateTime         @default(now())

  recipientUser    User?    @relation("NotifRecipientUser", fields: [recipientUserId], references: [id], onDelete: Cascade)
  recipientCompany Company? @relation("NotifRecipientCompany", fields: [recipientCompanyId], references: [id], onDelete: Cascade)
  actorUser        User?    @relation("NotifActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorCompany     Company? @relation("NotifActorCompany", fields: [actorCompanyId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, readAt])
  @@index([recipientCompanyId, readAt])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Saved (PRD §8). Users bookmark listings to revisit and optionally file them
// into named collections. One save per (user, listing); a save belongs to at
// most one collection (collectionId null = uncategorized).
// -----------------------------------------------------------------------------

model Collection {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items SavedListing[]

  @@unique([userId, name]) // collection names are unique per user
  @@index([userId])
}

model SavedListing {
  id           String   @id @default(cuid())
  userId       String
  listingId    String
  collectionId String? // null = uncategorized
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@unique([userId, listingId]) // a listing is saved at most once per user
  @@index([userId])
  @@index([listingId])
  @@index([collectionId])
}

// -----------------------------------------------------------------------------
// Reviews (PRD §7 + company-as-actor). Ratings accrue from COMPLETED deals: each
// side rates the other once. Both rater and ratee are PARTIES: the ratee is a
// user OR a company (so a company deal reviews the company, kept separate from
// its members' personal reviews); the rater is always the human who wrote it,
// optionally acting as a company (for "reviewed as <Company>" display).
// -----------------------------------------------------------------------------

model Review {
  id             String  @id @default(cuid())
  transactionId  String
  // Rater: the human who wrote it (always set) + the identity they acted as.
  raterUserId    String
  raterCompanyId String?
  // Ratee: who it's about - exactly one of these is set.
  rateeUserId    String?
  rateeCompanyId String?
  stars          Int // 1-5
  body           String?  @db.Text
  createdAt      DateTime @default(now())

  transaction  Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  raterUser    User        @relation("ReviewRaterUser", fields: [raterUserId], references: [id], onDelete: Cascade)
  raterCompany Company?    @relation("ReviewRaterCompany", fields: [raterCompanyId], references: [id], onDelete: SetNull)
  rateeUser    User?       @relation("ReviewRateeUser", fields: [rateeUserId], references: [id], onDelete: Cascade)
  rateeCompany Company?    @relation("ReviewRateeCompany", fields: [rateeCompanyId], references: [id], onDelete: Cascade)

  @@unique([transactionId, raterUserId]) // one review per person per deal
  @@index([rateeUserId])
  @@index([rateeCompanyId])
  @@index([createdAt])
}
